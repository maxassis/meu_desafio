{
  "name": "meu-desafio-monorepo",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "bun run --cwd apps/api dev",
    "dev:mobile": "bun run --cwd apps/mobile start",
    "start:api": "bun run --cwd apps/api start",
    "lint:api": "bun run --cwd apps/api lint",
    "lint:mobile": "bun run --cwd apps/mobile lint:eslint",
    "prisma:generate": "bun run --cwd apps/api prisma:generate",
    "prisma:migrate": "bun run --cwd apps/api prisma:migrate",
    "db:up": "podman compose -f apps/api/compose.yaml up -d",
    "db:down": "podman compose -f apps/api/compose.yaml down"
  }
}
